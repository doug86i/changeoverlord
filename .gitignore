api/.cache/
dist/
build/
*.log
coverage/
.idea/
.vscode/
docker-compose.override.yml
# Local Docker build-input stamps (scripts/docker-build-gate.sh)
.docker/
# Scratch workbook extractions (not versioned)
examples/*_live.json
examples/*_corrected.json
# Excel lock files
~$*
