# Copy to `.env` in the same folder as `docker-compose.yml`.
# Compose loads this automatically. Prefer the app UI for product settings.
#
# Deploy (pre-built app from GHCR, no local image build):
#   docker compose pull && docker compose up -d
#
# Develop (build app from this repo):
#   `make dev-fast` — hot reload (`docker-compose.fast.yml`)
#   `make dev` — classic image (`docker-compose.yml` + `docker-compose.dev.yml`)

# --- Infrastructure (keep in .env / compose; not duplicated in the UI) ---

# Single data root: PostgreSQL + user uploads. Default: ./data
# Linux example: DATA_DIR=/mnt/storage/changeoverlord
# Windows example (Docker Desktop): DATA_DIR=C:/changeoverlord/data
DATA_DIR=./data

# Host port for HTTP. Default 80 (no :port in the URL). Use 8080 if 80 is taken
# or on Windows when binding low ports requires elevated rights.
HOST_PORT=80

# App image tag from GHCR (CI publishes `latest` and semver tags).
APP_IMAGE_TAG=latest

# API logging: error | warn | info | debug | trace (see docs/LOGGING.md).
# Default in docker-compose.yml is `debug` for local testing; set `info` here for quieter logs on a show LAN.
LOG_LEVEL=debug

# HMAC secret for signed session cookies. The API image runs with NODE_ENV=production;
# startup fails if this is empty or left at the literal dev fallback string in code.
# Compose defaults to a placeholder if unset — replace with a long random value for real use.
# SESSION_SECRET=

# Comma-separated browser origins allowed for credentialed CORS when the API is not same-origin
# (e.g. Vite on :5173 talking to API on :3000). Leave unset for same-origin-only in production.
# CORS_ALLOWED_ORIGINS=http://localhost:5173

# Set to 1 so session cookies get the Secure flag (requires HTTPS or a terminating proxy).
# FORCE_SECURE_COOKIES=1

# --- Fast dev stack (`make dev-fast` only) ---
# Web UI (host port → Vite in-container 5173). Default 80 matches classic HOST_PORT; use 5173 if 80 is busy.
FAST_WEB_PORT=80
# FAST_API_PORT=3000

# API only — uploads root (Compose sets this; local dev defaults to ./data/uploads)
# UPLOADS_DIR=/var/changeoverlord/uploads

# Optional: comma-separated extra file extensions allowed for stage/performance attachments
# (e.g. .dsk,.show). These skip magic-byte checks — use only for trusted desk/show files.
# RIDER_EXTRA_EXTENSIONS=.dsk,.show
