# Copy to `.env` in the same folder as `docker-compose.yml`.
# Compose loads this automatically. Prefer the app UI for product settings.

# --- Infrastructure (keep in .env / compose; not duplicated in the UI) ---

# Single data root: PostgreSQL + user uploads. Default: ./data
# Linux example: DATA_DIR=/mnt/storage/changeoverlord
# Windows example (Docker Desktop): DATA_DIR=C:/changeoverlord/data
DATA_DIR=./data

# Host port for HTTP. Default 80 (no :port in the URL). Use 8080 if 80 is taken
# or on Windows when binding low ports requires elevated rights.
HOST_PORT=80

# App image tag from GHCR (CI publishes `latest` and semver tags).
APP_IMAGE_TAG=latest

# API logging: error | warn | info | debug | trace (see docs/LOGGING.md).
# Default in docker-compose.yml is `debug` for local testing; set `info` here for quieter logs on a show LAN.
LOG_LEVEL=debug

# HMAC secret for signed session cookies (set in production / CI)
# SESSION_SECRET=

# API only — uploads root (Compose sets this; local dev defaults to ./data/uploads)
# UPLOADS_DIR=/var/changeoverlord/uploads
